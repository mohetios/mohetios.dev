{
  "name": "mohetios-dev",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm gql:schema && concurrently -k -n velite,nuxt,email,system -c gray,cyan,green,magenta \"velite dev\" \"nuxt dev\" \"pnpm dev:email\" \"pnpm dev:system\"",
    "dev:web": "pnpm gql:schema && concurrently -k -n velite,nuxt -c gray,cyan \"velite dev\" \"nuxt dev\"",
    "dev:workers": "concurrently -k -n email,system -c green,magenta \"pnpm dev:email\" \"pnpm dev:system\"",
    "dev:email": "wrangler dev --config workers/email/wrangler.jsonc --env-file .env",
    "dev:system": "wrangler dev --config workers/system/wrangler.jsonc --env-file .env",
    "build": "velite build && pnpm gql:schema && NODE_OPTIONS=--max-old-space-size=4096 nuxt build --preset=cloudflare_pages",
    "gql:schema": "node scripts/sync-graphql-schema.mjs",
    "preview": "wrangler pages dev dist",
    "deploy": "wrangler pages deploy dist",
    "lint": "eslint app server shared workers scripts velite content",
    "lint:fix": "eslint app server shared workers scripts velite content --fix",
    "lint:vue": "node scripts/lint-vue-files.mjs",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "pnpm gql:schema && nuxt typecheck && pnpm typecheck:workers",
    "typecheck:workers": "tsc --noEmit -p workers/tsconfig.json",
    "check": "pnpm lint && pnpm lint:vue && pnpm typecheck",
    "knip": "knip",
    "clean": "rm -rf .nuxt .output .nitro .cache .velite dist .wrangler",
    "db:generate": "drizzle-kit generate",
    "db:push": "wrangler d1 migrations apply DB --local",
    "db:seed": "node scripts/seed-local-db.mjs",
    "db:studio": "drizzle-kit studio",
    "types:cloudflare": "wrangler types",
    "postinstall": "velite build && pnpm gql:schema && nuxt prepare"
  },
  "dependencies": {
    "@block65/webcrypto-web-push": "^1.0.2",
    "@graphql-tools/schema": "^10.0.33",
    "@iconify-json/lucide": "^1.2.111",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "^1.2.1",
    "@nuxt/ui": "^4.8.2",
    "@nuxtjs/i18n": "^10.4.0",
    "@nuxtjs/robots": "^6.0.9",
    "@nuxtjs/sitemap": "^8.1.0",
    "@nuxtjs/turnstile": "^1.1.3",
    "@resvg/resvg-js": "^2.6.2",
    "@shikijs/rehype": "^4.2.0",
    "@shikijs/transformers": "^4.2.0",
    "@stefanobartoletti/nuxt-social-share": "^3.0.3",
    "@vite-pwa/nuxt": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "graphql": "^16.14.2",
    "graphql-request": "^7.4.0",
    "graphql-yoga": "^5.21.2",
    "jose": "^6.2.3",
    "mermaid": "^11.15.0",
    "mimetext": "^3.0.28",
    "nuxt": "^4.4.8",
    "nuxt-booster": "^3.3.2",
    "nuxt-charts": "^2.1.4",
    "nuxt-graphql-client": "^0.2.46",
    "nuxt-og-image": "^6.5.3",
    "nuxt-security": "^2.6.0",
    "postal-mime": "^2.7.4",
    "satori": "^0.26.0",
    "shiki": "^4.2.0",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260610.1",
    "@eslint/markdown": "^8.0.2",
    "@nuxt/eslint": "^1.16.0",
    "@tailwindcss/typography": "^0.5.20",
    "@types/hast": "^3.0.4",
    "@types/node": "^25.9.2",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "knip": "^6.16.1",
    "nitro-cloudflare-dev": "^0.2.2",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "unist-util-visit": "^5.1.0",
    "velite": "^0.3.1",
    "vue-tsc": "^3.3.4",
    "wrangler": "^4.99.0"
  },
  "packageManager": "pnpm@11.5.3"
}
