{
  "name": "mohetios-dev",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "velite dev & nuxt dev",
    "build": "velite build && NODE_OPTIONS=--max-old-space-size=4096 nuxt build",
    "build:pages": "velite build && NODE_OPTIONS=--max-old-space-size=4096 nuxi build --preset=cloudflare_pages",
    "preview": "wrangler pages dev dist",
    "preview:pages": "wrangler pages dev dist",
    "deploy": "wrangler pages deploy dist",
    "deploy:pages": "wrangler pages deploy dist",
    "types:cloudflare": "wrangler types",
    "postinstall": "velite build && nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "velite build && nuxt typecheck",
    "db:generate": "drizzle-kit generate",
    "db:push": "wrangler d1 migrations apply DB --local",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@graphql-tools/schema": "^10.0.33",
    "@iconify-json/lucide": "^1.2.111",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "^1.1.1",
    "@nuxt/ui": "^4.8.1",
    "@nuxtjs/i18n": "^10.4.0",
    "@nuxtjs/robots": "^5.7.1",
    "@nuxtjs/sitemap": "^7.6.0",
    "@nuxtjs/turnstile": "^1.1.3",
    "drizzle-orm": "^0.45.2",
    "graphql": "^16.14.0",
    "graphql-request": "^7.4.0",
    "graphql-yoga": "^5.21.0",
    "jose": "^6.2.3",
    "nuxt": "^4.4.6",
    "nuxt-charts": "^2.1.4",
    "nuxt-graphql-client": "^0.2.46",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260528.1",
    "@nuxt/eslint": "^1.15.2",
    "@types/node": "^25.9.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "nitro-cloudflare-dev": "^0.2.2",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "velite": "^0.3.1",
    "vue-tsc": "^3.3.3",
    "wrangler": "^4.95.0"
  },
  "packageManager": "pnpm@11.5.0"
}
