{
  "version": "3.0.0",
  "default_content_paths": [
    "**/*.md",
    "**/*.mdx",
    "**/*.txt",
    "**/*.yaml",
    "**/*.yml",
    "**/*.json"
  ],
  "exclude_paths": [
    "node_modules/**",
    ".git/**",
    "dist/**",
    "build/**",
    ".output/**",
    ".nuxt/**",
    ".pnpm-store/**",
    ".velite/**",
    "coverage/**",
    "public/**",
    "package.json",
    "pnpm-lock.yaml",
    "*/editorial-config.json",
    "editorial/fa/evaluation/**",
    "editorial/fa/profiles/ali/anti-patterns.md",
    "editorial/fa/profiles/ali/corpus/contrastive/**",
    "editorial/fa/profiles/ali/corpus/rejected/**",
    "editorial/fa/_legacy/**",
    ".editorial-engine-backups/**",
    "persian-editorial-engine-v*/**"
  ],
  "forbidden_phrases": [
    "در دنیای امروز",
    "در عصر دیجیتال",
    "با پیشرفت روزافزون فناوری",
    "در این مقاله قصد داریم",
    "شایان ذکر است",
    "لازم به ذکر است",
    "راهکاری نوآورانه و انقلابی",
    "تجربه‌ای بی‌نظیر",
    "تحولی شگرف",
    "گامی بزرگ در راستای",
    "با افتخار اعلام می‌کنیم",
    "همه‌چیز را تغییر می‌دهد"
  ],
  "suspicious_phrases": [
    "بدون شک",
    "بی‌شک",
    "بهترین",
    "کامل‌ترین",
    "بی‌رقیب",
    "راهکار جامع",
    "نسل آینده",
    "فوق‌امن",
    "کاملاً مقیاس‌پذیر",
    "production-ready",
    "آماده‌ی production",
    "صددرصد",
    "همیشه",
    "هرگز"
  ],
  "high_risk_claims": [
    "غیرقابل هک",
    "امنیت صددرصد",
    "ناشناس مطلق",
    "ناشناسی کامل",
    "کاملاً غیرقابل ردیابی",
    "هیچ داده‌ای ذخیره نمی‌شود",
    "رمزنگاری سرتاسری",
    "end-to-end encrypted"
  ],
  "arabic_characters": {
    "ي": "ی",
    "ك": "ک"
  },
  "max_paragraph_chars_warning": 1000,
  "max_heading_depth": 4,
  "max_consecutive_blank_lines": 2,
  "allowed_suppressions": ["editorial-lint-disable-next-line", "editorial-lint-disable-file"]
}
